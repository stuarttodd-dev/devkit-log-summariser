{
    "name": "devkit/log-summariser",
    "description": "Groups and summarises PHP/Laravel log errors with report output",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "bin": [
        "bin/devkit-log-summarise"
    ],
    "autoload": {
        "psr-4": {
            "Devkit\\LogSummariser\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Stuart Todd"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "squizlabs/php_codesniffer": "^3.10",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.12",
        "rector/rector": "^1.2",
        "pestphp/pest-plugin-drift": "^3.0"
    },
    "scripts": {
        "tests": "./vendor/bin/pest",
        "phpcs": "./vendor/bin/phpcs --standard=PSR12 --report=summary src/ bin/",
        "phpcbf": "./vendor/bin/phpcbf --standard=PSR12 src/ bin/",
        "phpmd": "./vendor/bin/phpmd src/ text cleancode,codesize,controversial,design,naming,unusedcode",
        "phpstan": "./vendor/bin/phpstan analyse src/ bin/ --level max",
        "rector:dry-run": "./vendor/bin/rector process --dry-run",
        "rector": "./vendor/bin/rector process",
        "standards:check": [
            "@phpcs",
            "@phpmd",
            "@phpstan",
            "@rector:dry-run"
        ],
        "standards:fix": [
            "@phpcbf",
            "@rector"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
