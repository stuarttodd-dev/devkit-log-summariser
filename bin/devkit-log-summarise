#!/usr/bin/env php
<?php

declare(strict_types=1);

use Devkit\LogSummariser\Console\SummariseCommand;
use Symfony\Component\Console\Application;

$autoload = dirname(__DIR__) . '/vendor/autoload.php';
if (! is_file($autoload)) {
    fwrite(STDERR, "Run composer install first.\n");
    exit(1);
}

require $autoload;

$application = new Application('devkit-log-summarise', '1.0.0');
$application->add(new SummariseCommand());
$application->setDefaultCommand('summarise', true);
$application->run();
